# Copy this file to .env and fill in real values for local development.
# On Railway/Render, set these as environment variables in the dashboard
# instead — do not commit a real .env file to version control.

# Provided automatically by Railway/Render when you attach a Postgres
# database. For local dev, point this at your own local Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/radah_pm

# Generate a long random string, e.g.: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-secret

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGIN=http://localhost:5173

PORT=4000
NODE_ENV=development

# Used only by db/seed.js to create the first admin login.
ADMIN_EMAIL=admin@radahpm.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=RADAH Admin
